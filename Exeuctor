<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mixrowave Executor</title>

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">

    <style>
        *{  
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Outfit',sans-serif;
        }

        body{
            background:#050505;
            color:white;
            overflow-x:hidden;
        }

        body::before{
            content:"";
            position:fixed;
            inset:0;
            background:
            radial-gradient(circle at 20% 20%,#7b2fff33,transparent 30%),
            radial-gradient(circle at 80% 70%,#3d8cff33,transparent 30%);
            filter:blur(80px);
            z-index:-1;
        }

        nav{
            position:fixed;
            width:100%;
            padding:20px 10%;
            display:flex;
            justify-content:space-between;
            align-items:center;
            backdrop-filter:blur(15px);
            background:rgba(0,0,0,.25);
            border-bottom:1px solid #ffffff15;
            z-index:100;
        }

        nav h1{
            color:#9b5cff;
            text-shadow:0 0 20px #8d39ff;
        }

        nav ul{
            display:flex;
            gap:30px;
            list-style:none;
        }

        nav a{
            color:white;
            text-decoration:none;
            transition:.3s;
        }

        nav a:hover{
            color:#9b5cff;
        }

        .hero{
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            flex-direction:column;
            text-align:center;
            animation:fade 1s;
        }

        h2{
            font-size:70px;
            text-shadow:0 0 30px #8a2eff;
        }

        .hero p{
            margin:20px;
            color:#bbb;
            font-size:20px;
        }

        .badge{
            margin:20px;
            background:#8a2eff22;
            border:1px solid #8a2eff;
            padding:10px 25px;
            border-radius:40px;
            box-shadow:0 0 30px #8a2eff55;
        }

        .buttons{
            display:flex;
            gap:20px;
        }

        button{
            padding:15px 35px;
            border:none;
            border-radius:15px;
            background:#8a2eff;
            color:white;
            font-size:18px;
            cursor:pointer;
            transition:.3s;
            box-shadow:0 0 25px #8a2eff;
        }

        button:hover{
            transform:translateY(-5px) scale(1.05);
            box-shadow:0 0 40px #8a2eff;
        }

        section{
            padding:100px 10%;
        }

        .title{
            text-align:center;
            font-size:40px;
            margin-bottom:50px;
        }

        .grid{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:25px;
        }

        .card{
            background:#101010;
            padding:30px;
            border-radius:20px;
            border:1px solid #ffffff10;
            transition:.3s;
        }

        .card:hover{
            transform:translateY(-8px);
            box-shadow:0 0 35px #8a2eff66;
        }

        .review{
            background:#111;
            padding:25px;
            border-radius:20px;
            transition:.3s;
        }

        .review:hover{
            transform:translateY(-5px);
            box-shadow:0 0 25px #8a2eff66;
        }

        footer{
            padding:40px;
            text-align:center;
            color:#888;
        }

        @keyframes fade{
            from{
                opacity:0;
                transform:translateY(50px);
            }
            to{
                opacity:1;
                transform:translateY(0);
            }
        }
    </style>
</head>
